{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo build (debug)",
            "type": "shell",
            "command": "${env:USERPROFILE}/.cargo/bin/cargo build --bin cmp",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$rustc",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "cargo build (release)",
            "type": "shell",
            "command": "${env:USERPROFILE}/.cargo/bin/cargo build --bin cmp --release",
            "group": "build",
            "problemMatcher": "$rustc",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "cargo build (debug, tracker)",
            "type": "shell",
            "command": "${env:USERPROFILE}/.cargo/bin/cargo build --bin cmp --features tracker",
            "group": "build",
            "problemMatcher": "$rustc",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "cargo build (release, tracker)",
            "type": "shell",
            "command": "${env:USERPROFILE}/.cargo/bin/cargo build --bin cmp --release --features tracker",
            "group": "build",
            "problemMatcher": "$rustc",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ]
}
